#
# Dump/search with:
#   ./island.sh dump "$ECDSAFAIL_CFG_1216_BALANCED" s-1216-balanced.bin
#   GPU_BATCH_INV=1 GPU_COMB_BITS=22 GPU_GCD_MODE=trunc_first GPU_FAN_BITS=22 GPU_WAVE=128 \
#     ./island.sh search s-1216-balanced.bin <START> <N>
#
# Validate candidates both ways:
#   EVAL_FAST_REJECT=1 ./island.sh validate "$ECDSAFAIL_CFG_1216_BALANCED" <nonce...>
#   EVAL_FAST_REJECT=0 ./island.sh validate "$ECDSAFAIL_CFG_1216_BALANCED" <nonce...>

ECDSAFAIL_CFG_1216_BALANCED="DIALOG_GCD_APPLY_FUSED_FOLD=0 ROUND84_FOLD_FAST_ADD=0 SQUARE_ROW_MAX_SEG=184 DIALOG_GCD_APPLY_CHUNKED_F_BLOCKS=12"

